# Rendered by Ansible (plane-bootstrap). Do not edit by hand.
# Topology verified against makeplane/plane v1.3.1 docker-compose.yml.
# Differences from upstream, on purpose:
#   * external AWS S3 instead of the bundled plane-minio (dropped)
#   * Postgres bind-mounted to the persistent EBS volume ({{ postgres_data_dir }})
#   * proxy (Caddy) runs HTTP-only, bound to localhost; host nginx terminates TLS

x-app-env: &app-env
  env_file:
    - .env
  restart: unless-stopped

services:
  plane-db:
    image: {{ postgres_image }}
    restart: unless-stopped
    command: postgres -c 'max_connections=1000'
    env_file:
      - .env
    volumes:
      - {{ postgres_data_dir }}:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ postgres_user }} -d {{ postgres_db }}"]
      interval: 10s
      timeout: 5s
      retries: 10

  plane-redis:
    image: {{ redis_image }}
    restart: unless-stopped
    # Ephemeral cache/broker-helper — no volume on purpose.

  plane-mq:
    image: {{ rabbitmq_image }}
    restart: unless-stopped
    env_file:
      - .env
    environment:
      RABBITMQ_DEFAULT_USER: "{{ rabbitmq_user }}"
      RABBITMQ_DEFAULT_PASS: "{{ rabbitmq_password }}"
      RABBITMQ_DEFAULT_VHOST: "{{ rabbitmq_vhost }}"
    # Ephemeral broker — no volume on purpose.

  migrator:
    image: {{ plane_images.backend }}
    restart: "no"
    <<: *app-env
    command: ["./bin/docker-entrypoint-migrator.sh"]
    depends_on:
      plane-db:
        condition: service_healthy
      plane-redis:
        condition: service_started
      plane-mq:
        condition: service_started

  api:
    image: {{ plane_images.backend }}
    <<: *app-env
    command: ["./bin/docker-entrypoint-api.sh"]
    depends_on:
      migrator:
        condition: service_completed_successfully

  worker:
    image: {{ plane_images.backend }}
    <<: *app-env
    command: ["./bin/docker-entrypoint-worker.sh"]
    depends_on:
      api:
        condition: service_started

  beat-worker:
    image: {{ plane_images.backend }}
    <<: *app-env
    command: ["./bin/docker-entrypoint-beat.sh"]
    depends_on:
      api:
        condition: service_started

  live:
    image: {{ plane_images.live }}
    <<: *app-env
    depends_on:
      api:
        condition: service_started

  web:
    image: {{ plane_images.web }}
    <<: *app-env
    depends_on:
      api:
        condition: service_started

  space:
    image: {{ plane_images.space }}
    <<: *app-env
    depends_on:
      api:
        condition: service_started
      web:
        condition: service_started

  admin:
    image: {{ plane_images.admin }}
    <<: *app-env
    depends_on:
      api:
        condition: service_started
      web:
        condition: service_started

  proxy:
    image: {{ plane_images.proxy }}
    <<: *app-env
    ports:
      # Caddy serves HTTP on 80 inside the container; publish to localhost only.
      # Host nginx terminates TLS on 443 and proxies here.
      - "{{ plane_proxy_host }}:{{ plane_proxy_port }}:80"
    depends_on:
      - web
      - api
      - space
      - admin
      - live
