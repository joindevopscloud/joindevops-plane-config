# Rendered by Ansible (plane-bootstrap). Do not edit by hand.
# Variable set verified against makeplane/plane v1.3.1 .env.example + setup.sh.
# Secrets come from persistent files on {{ secrets_dir }} and from SSM.

# --- Core (SECRET_KEY is generated by setup.sh upstream; we persist our own) ---
SECRET_KEY={{ plane_secret_key }}
WEB_URL={{ plane_web_url }}
CORS_ALLOWED_ORIGINS={{ plane_web_url }}
DEBUG=0
GUNICORN_WORKERS=2

# --- Postgres (bind-mounted to {{ postgres_data_dir }}) ---
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ postgres_password }}
POSTGRES_DB={{ postgres_db }}
PGHOST=plane-db
PGDATA=/var/lib/postgresql/data
DATABASE_URL=postgresql://{{ postgres_user }}:{{ postgres_password }}@plane-db:5432/{{ postgres_db }}

# --- Redis / Valkey (ephemeral) ---
REDIS_HOST=plane-redis
REDIS_PORT=6379
REDIS_URL=redis://plane-redis:6379/

# --- RabbitMQ (broker, required in v1.x; ephemeral) ---
RABBITMQ_HOST=plane-mq
RABBITMQ_PORT=5672
RABBITMQ_USER={{ rabbitmq_user }}
RABBITMQ_PASSWORD={{ rabbitmq_password }}
RABBITMQ_VHOST={{ rabbitmq_vhost }}
AMQP_URL=amqp://{{ rabbitmq_user }}:{{ rabbitmq_password }}@plane-mq:5672/{{ rabbitmq_vhost }}

# --- File storage: external AWS S3 (no MinIO) ---
# AWS_S3_ENDPOINT_URL is intentionally empty -> real AWS S3. Credentials are
# resolved from the EC2 instance IAM role via IMDS (requires metadata hop
# limit >= 2, set in plane-infra ec2.tf).
USE_MINIO={{ use_minio }}
AWS_REGION={{ aws_region }}
AWS_S3_BUCKET_NAME={{ s3_bucket_name }}
AWS_S3_ENDPOINT_URL=
FILE_SIZE_LIMIT={{ file_size_limit }}

# --- Proxy (Caddy). HTTP only, on localhost; host nginx does TLS in front. ---
SITE_ADDRESS=:80
LISTEN_HTTP_PORT=80
TRUSTED_PROXIES=0.0.0.0/0

# --- SMTP ---
# NOT configured here. In v1.3.1, SMTP is set in the God Mode admin UI at
# {{ plane_web_url }}/god-mode/ using the credentials stored in SSM
# (/plane/smtp_username, /plane/smtp_password).

DOCKERIZED=1
